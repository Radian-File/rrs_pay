<UserControl x:Class="rrs_pay.Views.Pages.EmployeesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:rrs_pay.ViewModels.Pages"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1080">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Views/Shared/PageStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <UserControl.DataContext>
        <vm:EmployeesViewModel />
    </UserControl.DataContext>

    <Grid Background="{StaticResource PageBackgroundBrush}" Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Employees" Style="{StaticResource PageTitleText}" />
            <TextBlock Text="Search, add, and edit employee payroll master data." Foreground="{StaticResource SecondaryTextBrush}" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="0.9*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,14,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="Employee Directory" Style="{StaticResource SectionTitleText}" />
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputTextBoxStyle}"
                                 ToolTip="Search by code, name, department, or position" />
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding FilteredEmployees}"
                              SelectedItem="{Binding SelectedEmployee, Mode=TwoWay}"
                              Style="{StaticResource DarkDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding EmployeeCode}" Width="100" />
                            <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="1.6*" />
                            <DataGridTextColumn Header="Department" Binding="{Binding Department}" Width="1.1*" />
                            <DataGridTextColumn Header="Position" Binding="{Binding Position}" Width="1.2*" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                            <DataGridTextColumn Header="Basic Salary" Binding="{Binding BasicSalary, StringFormat={}{0:N0}}" Width="120" />
                            <DataGridTextColumn Header="Bank" Binding="{Binding BankName}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Add / Edit Employee" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Text="Employee Code" Style="{StaticResource CaptionText}" />
                        <TextBox Text="{Binding EmployeeCode, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />

                        <TextBlock Text="Full Name" Style="{StaticResource CaptionText}" />
                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />

                        <TextBlock Text="Department" Style="{StaticResource CaptionText}" />
                        <ComboBox ItemsSource="{Binding Departments}" SelectedItem="{Binding Department}" Style="{StaticResource InputComboBoxStyle}" />

                        <TextBlock Text="Position" Style="{StaticResource CaptionText}" />
                        <ComboBox ItemsSource="{Binding Positions}" SelectedItem="{Binding Position}" Style="{StaticResource InputComboBoxStyle}" />

                        <TextBlock Text="Employment Status" Style="{StaticResource CaptionText}" />
                        <ComboBox ItemsSource="{Binding EmploymentStatuses}" SelectedItem="{Binding EmploymentStatus}" Style="{StaticResource InputComboBoxStyle}" />

                        <TextBlock Text="Basic Salary" Style="{StaticResource CaptionText}" />
                        <TextBox Text="{Binding BasicSalary, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N0}}" Style="{StaticResource InputTextBoxStyle}" />

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="Save" Command="{Binding SaveEmployeeCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                            <Button Content="New" Command="{Binding ClearFormCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                        </StackPanel>

                        <TextBlock Text="Selecting a grid row loads it into the form. Data services can replace this sample collection later."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,16,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
