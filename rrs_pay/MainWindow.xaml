<Window x:Class="rrs_pay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:rrs_pay.ViewModels"
        mc:Ignorable="d"
        Title="RRS Pay"
        Height="820"
        Width="1280"
        MinHeight="720"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=True}">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushDark}"
                BorderThickness="0,0,1,0">
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,6,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="46" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="42"
                                Height="42"
                                CornerRadius="13"
                                Background="{StaticResource AccentMutedBrush}">
                            <TextBlock Text="R"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                            <TextBlock Text="RRS Pay" FontSize="18" FontWeight="Bold" />
                            <TextBlock Text="Payroll Operations" Style="{StaticResource MutedTextBlockStyle}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding NavigationItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton GroupName="PrimaryNavigation"
                                             Content="{Binding Title}"
                                             Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                             CommandParameter="{Binding}"
                                             IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                             Style="{StaticResource SidebarNavRadioStyle}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="14" CornerRadius="14">
                    <StackPanel>
                        <TextBlock Text="Signed in" Style="{StaticResource MutedTextBlockStyle}" />
                        <TextBlock Text="Administrator" FontWeight="SemiBold" Margin="0,4,0,0" />
                        <Border Style="{StaticResource SuccessBadgeBorderStyle}"
                                HorizontalAlignment="Left"
                                Margin="0,10,0,0">
                            <TextBlock Text="MVP Workspace" Foreground="{StaticResource SuccessBrush}" Style="{StaticResource BadgeTextStyle}" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main workspace -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="82" />
                <RowDefinition Height="*" />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource AppBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="0,0,0,1"
                    Padding="28,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="340" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentPageTitle}" Style="{StaticResource PageTitleTextStyle}" />
                        <TextBlock Text="{Binding CurrentPageSubtitle}" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,4,0,0" />
                    </StackPanel>

                    <TextBox Grid.Column="1"
                             Height="40"
                             VerticalAlignment="Center"
                             Text="Search payroll, employees, reports..."
                             Foreground="{StaticResource TextSecondaryBrush}" />

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="18,0,0,0">
                        <Button Content="New Payroll Run"
                                Command="{Binding NewPayrollRunCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Content="Alerts"
                                Command="{Binding AlertsCommand}"
                                Style="{StaticResource GhostButtonStyle}"
                                Margin="10,0,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content host -->
            <Border Grid.Row="1" Background="{StaticResource AppBackgroundBrush}">
                <ContentControl Content="{Binding CurrentPage}" Margin="28" />
            </Border>

            <!-- Status bar -->
            <Border Grid.Row="2"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="0,1,0,0"
                    Padding="18,0">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Left"
                               Text="Ready"
                               Style="{StaticResource MutedTextBlockStyle}"
                               VerticalAlignment="Center" />
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding StatusText}"
                               Style="{StaticResource MutedTextBlockStyle}"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
